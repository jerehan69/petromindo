---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | Blog`} description={post.data.description}>
  <div class="project-detail container">
    <a href="/blog" class="back-link">&larr; All posts</a>
    <h1>{post.data.title}</h1>
    <div class="meta">
      <span class="mono">{post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</span>
      {post.data.tags && (
        <>
          <span>•</span>
          {post.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </>
      )}
    </div>

    <div class="project-content">
      <Content />
    </div>
  </div>
</BaseLayout>
