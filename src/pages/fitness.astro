---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Fitness | Walk Library" description="GPS-tracked walks with animated route playback" activePage="fitness">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <style is:global>
    html, body { height: 100vh; overflow: hidden; } body { display: flex; flex-direction: column; } main { display: flex; flex-direction: column; flex: 1; min-height: 0; } footer { display: none !important; }
    .fitness-wrap { display: flex; flex: 1; margin: 0; max-width: none; padding: 0; min-height: 0; }
    .map-wrap { flex: 1; display: flex; flex-direction: column; min-width: 0; position: relative; }
    #map { flex: 1; }

    .overlay {
      position: absolute; top: 10px; left: 10px; right: 10px; z-index: 1000;
      background: rgba(10,10,30,0.88); backdrop-filter: blur(8px);
      border: 1px solid #2a2a4a; border-radius: 12px;
      padding: 8px 16px; display: flex; gap: 18px; align-items: center;
      font-size: 13px; flex-wrap: wrap;
    }
    .overlay .stat { display: flex; align-items: center; gap: 4px; }
    .overlay .stat .val { font-weight: 700; color: #fff; font-size: 15px; }
    .overlay .stat .lbl { color: #666; font-size: 11px; }

    .sidebar {
      width: 340px; background: #0e0e22; border-left: 1px solid #1e1e3a;
      display: flex; flex-direction: column; flex-shrink: 0;
    }
    .sidebar-header {
      padding: 14px 16px; font-size: 13px; color: #666; text-transform: uppercase;
      letter-spacing: 1px; border-bottom: 1px solid #1a1a30;
    }
    .sidebar-list { flex: 1; overflow-y: auto; }
    .walk-item {
      padding: 10px 16px; border-bottom: 1px solid #14142a; cursor: pointer;
      transition: background 0.15s; display: flex; gap: 10px; align-items: center;
    }
    .walk-item:hover { background: #18183a; }
    .walk-item.active { background: #1a2a4a; border-left: 3px solid #4fc3f7; padding-left: 13px; }
    .walk-item.no-gpx { opacity: 0.45; cursor: default; }
    .walk-item.no-gpx:hover { background: transparent; }
    .walk-item .dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .walk-item .dot.has { background: #4fc3f7; }
    .walk-item .dot.none { background: #333; }
    .walk-item .wi-body { flex: 1; min-width: 0; }
    .walk-item .wi-name { font-size: 13px; font-weight: 600; color: #ddd; }
    .walk-item .wi-meta { font-size: 11px; color: #666; margin-top: 2px; display: flex; gap: 10px; flex-wrap: wrap; }
    .walk-item .wi-meta span { white-space: nowrap; }
    .walk-item .wi-dist { font-size: 15px; font-weight: 700; color: #4fc3f7; flex-shrink: 0; }

    .controls {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 16px; background: #12122a;
      border-top: 1px solid #1e1e3a; flex-shrink: 0; flex-wrap: wrap;
    }
    .controls button {
      background: #1e1e3a; color: #fff; border: none;
      padding: 6px 12px; border-radius: 6px; cursor: pointer;
      font-size: 13px; font-weight: 600; transition: background 0.2s;
    }
    .controls button:hover { background: #2a2a5a; }
    .speed-btn { font-size: 11px !important; padding: 4px 8px !important; background: #16163a !important; }
    .speed-btn.active { background: #2a2a5a !important; outline: 2px solid #4fc3f7; }
    .progress-wrap { flex: 1; min-width: 60px; display: flex; align-items: center; gap: 6px; }
    .progress-wrap input[type="range"] {
      flex: 1; height: 3px; -webkit-appearance: none; appearance: none;
      background: #1a1a30; border-radius: 2px; outline: none;
    }
    .progress-wrap input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none; width: 12px; height: 12px; border-radius: 50%;
      background: #4fc3f7; cursor: pointer;
    }
    .speed-group { display: flex; gap: 2px; }

    .fit-tabs { display: flex; gap: 0; background: #0a0a1e; border-bottom: 1px solid #1e1e3a; flex-shrink: 0; }
    .fit-tab { background: none; border: none; color: #666; padding: 10px 20px; font-size: 13px; font-weight: 600; cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.2s; }
    .fit-tab:hover { color: #aaa; }
    .fit-tab.active { color: #4fc3f7; border-bottom-color: #4fc3f7; }
    .tab-content { display: none; flex: 1; min-height: 0; flex-direction: column; }
    .tab-content.active { display: flex; }

    .dash-wrap { display: flex; flex-direction: column; flex: 1; min-height: 0; background: #0a0a1e; }
    .dash-header { padding: 12px 20px; font-size: 15px; font-weight: 700; color: #fff; border-bottom: 1px solid #1e1e3a; flex-shrink: 0; }
    .dash-tabs { display: flex; gap: 0; background: #0e0e22; border-bottom: 1px solid #1e1e3a; flex-shrink: 0; overflow-x: auto; }
    .dash-tab { background: none; border: none; color: #666; padding: 8px 16px; font-size: 12px; font-weight: 600; cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.2s; white-space: nowrap; }
    .dash-tab:hover { color: #aaa; }
    .dash-tab.active { color: #4fc3f7; border-bottom-color: #4fc3f7; }
    .dash-content { display: none; flex: 1; min-height: 0; overflow-y: auto; padding: 16px; }
    .dash-content.active { display: block; }

    .dash-card { background: #12122a; border: 1px solid #1e1e3a; border-radius: 10px; padding: 14px 16px; margin-bottom: 12px; }
    .dash-card h3 { font-size: 12px; color: #666; text-transform: uppercase; letter-spacing: 0.5px; margin: 0 0 10px 0; }
    .dash-card .val { font-size: 24px; font-weight: 700; color: #fff; }
    .dash-card .sub { font-size: 11px; color: #666; margin-top: 2px; }
    .dash-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; margin-bottom: 12px; }
    .dash-grid .dash-card { margin-bottom: 0; }
    .dash-chart { height: 200px; position: relative; }
    .dash-chart-lg { height: 280px; position: relative; }
    .sleep-bar { display: flex; height: 24px; border-radius: 4px; overflow: hidden; margin-top: 8px; }
    .sleep-bar div { height: 100%; }
    .sleep-deep { background: #4a90d9; }
    .sleep-light { background: #87ceeb; }
    .sleep-rem { background: #9b59b6; }
    .sleep-awake { background: #e74c3c; }
    .sleep-timeline { font-size: 11px; color: #666; margin-top: 4px; display: flex; justify-content: space-between; }
    .stat-row { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #1a1a30; font-size: 12px; }
    .stat-row:last-child { border-bottom: none; }
    .stat-row .lbl { color: #888; }
    .stat-row .val { color: #fff; font-weight: 600; }
    .hrv-badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 600; }
    .hrv-good { background: #1b5e20; color: #4caf50; }
    .hrv-moderate { background: #e6510020; color: #ff9800; }
    .hrv-low { background: #b71c1c20; color: #f44336; }

    @media (max-width: 800px) {
      .fitness-wrap { flex-direction: column; height: auto; }
      .sidebar { width: 100%; max-height: 200px; border-left: none; border-top: 1px solid #1e1e3a; }
      .map-wrap { height: 50vh; }
    }
  </style>

  <div class="fit-tabs">
    <button class="fit-tab active" data-tab="walks">🚶 Walks</button>
    <button class="fit-tab" data-tab="dashboard">📊 Dashboard</button>
  </div>

  <div id="tab-walks" class="tab-content active">
    <div class="fitness-wrap">
      <div class="map-wrap">
        <div id="map"></div>
        <div class="overlay">
          <div class="stat"><span class="val" id="ovTime">0:00</span><span class="lbl">/ <span id="ovTotal">0:00</span></span></div>
          <div class="stat"><span class="val" id="ovDist">0.00</span><span class="lbl">km</span></div>
          <div class="stat"><span class="val" id="ovPace">--</span><span class="lbl">min/km</span></div>
          <div class="stat"><span class="val" id="ovSteps">0</span><span class="lbl">steps</span></div>
          <div class="stat"><span class="val" id="ovCal">0</span><span class="lbl">cal</span></div>
        </div>
      </div>
      <div class="sidebar">
        <div class="sidebar-header">🚶 Walking History</div>
        <div class="sidebar-list" id="walkList"></div>
      </div>
    </div>
    <div class="controls">
      <button id="playBtn">▶ Play</button>
      <button id="resetBtn">⟲ Reset</button>
      <div class="progress-wrap">
        <input type="range" id="slider" min="0" max="1000" value="0">
        <span style="font-size:11px;color:#4fc3f7;min-width:30px;text-align:right" id="pctDisp">0%</span>
      </div>
      <div class="speed-group">
        <button class="speed-btn" data-speed="0.5">½×</button>
        <button class="speed-btn active" data-speed="1">1×</button>
        <button class="speed-btn" data-speed="2">2×</button>
        <button class="speed-btn" data-speed="5">5×</button>
        <button class="speed-btn" data-speed="10">10×</button>
      </div>
    </div>
  </div>

  <div id="tab-dashboard" class="tab-content">
    <div class="dash-wrap">
      <div class="dash-header">Health Dashboard</div>
      <div class="dash-tabs">
        <button class="dash-tab active" data-dtab="overview">Overview</button>
        <button class="dash-tab" data-dtab="sleep">Sleep</button>
        <button class="dash-tab" data-dtab="heart">Heart Rate</button>
        <button class="dash-tab" data-dtab="activity">Activity</button>
        <button class="dash-tab" data-dtab="health">Health</button>
      </div>
      <div class="dash-content" id="dash-overview"></div>
      <div class="dash-content" id="dash-sleep"></div>
      <div class="dash-content" id="dash-heart"></div>
      <div class="dash-content" id="dash-activity"></div>
      <div class="dash-content" id="dash-health"></div>
    </div>
  </div>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script>
    let WALKS = [], GPX = {};
    let currentWalkId = null, gpxData = null, N = 0, pointTime = null, routeCoords = null, cumDist = null;
    let idx = 0, playing = false, speed = 1, timer = null, animStartWall = 0, animStartPoint = 0;

    const $ = id => document.getElementById(id);
    const playBtn = $('playBtn'), resetBtn = $('resetBtn'), slider = $('slider');
    const pctDisp = $('pctDisp'), ovTime = $('ovTime'), ovTotal = $('ovTotal');
    const ovDist = $('ovDist'), ovPace = $('ovPace'), ovSteps = $('ovSteps'), ovCal = $('ovCal');
    const walkList = $('walkList');

    const map = L.map('map', { zoomControl: true, attributionControl: false });
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      maxZoom: 20, attribution: '&copy; OSM &copy; CARTO'
    }).addTo(map);

    let routeLine, trailLine, marker, startMarker, endMarker;
    function clearMap() {
      [routeLine, trailLine, marker, startMarker, endMarker].forEach(l => { if(l) map.removeLayer(l); });
    }

    function loadWalk(id) {
      pause(); clearMap();
      const walk = WALKS.find(w => w.id === id);
      if (!walk || !GPX[id]) return;
      currentWalkId = id;
      gpxData = GPX[id];
      N = gpxData.length;
      const startMs = new Date(gpxData[0].t).getTime();
      pointTime = new Float64Array(N);
      routeCoords = new Array(N);
      for (let i = 0; i < N; i++) {
        pointTime[i] = (new Date(gpxData[i].t).getTime() - startMs) / 1000;
        routeCoords[i] = [gpxData[i].lat, gpxData[i].lon];
      }
      cumDist = new Float64Array(N);
      for (let i = 1; i < N; i++) {
        const dLat = (gpxData[i].lat - gpxData[i-1].lat) * Math.PI / 180;
        const dLon = (gpxData[i].lon - gpxData[i-1].lon) * Math.PI / 180;
        const a = Math.sin(dLat/2)**2 + Math.cos(gpxData[i-1].lat*Math.PI/180) * Math.cos(gpxData[i].lat*Math.PI/180) * Math.sin(dLon/2)**2;
        cumDist[i] = cumDist[i-1] + 6371000 * 2 * Math.asin(Math.sqrt(a));
      }
      setTimeout(() => {
        map.invalidateSize();
        map.fitBounds(L.latLngBounds(routeCoords), { padding: [50, 50] });
        setTimeout(() => {
          map.invalidateSize();
          map.fitBounds(L.latLngBounds(routeCoords), { padding: [50, 50] });
        }, 1000);
      }, 500);
      routeLine = L.polyline(routeCoords, { color: '#4fc3f7', weight: 3, opacity: 0.35 }).addTo(map);
      trailLine = L.polyline([], { color: '#ff6b6b', weight: 4, opacity: 0.9 }).addTo(map);
      marker = L.circleMarker(routeCoords[0], { radius: 7, color: '#ff6b6b', fillColor: '#ff6b6b', fillOpacity: 1, weight: 2 }).addTo(map);
      startMarker = L.circleMarker(routeCoords[0], { radius: 5, color: '#4caf50', fillColor: '#4caf50', fillOpacity: 0.8 }).addTo(map).bindTooltip('Start');
      endMarker = L.circleMarker(routeCoords[N-1], { radius: 5, color: '#f44336', fillColor: '#f44336', fillOpacity: 0.8 }).addTo(map).bindTooltip('End');
      ovTotal.textContent = fmtTime(pointTime[N-1]);
      document.querySelectorAll('.walk-item').forEach(el => el.classList.remove('active'));
      const el = document.querySelector('.walk-item[data-id="' + id + '"]');
      if (el) el.classList.add('active');
      idx = 0; draw(0);
    }

    function fmtTime(s) { const m = Math.floor(s/60), sec = Math.floor(s%60); return m + ':' + (sec<10?'0':'') + sec; }

    function draw(i) {
      if (!gpxData) return;
      if (i < 0) i = 0; if (i >= N) i = N-1;
      idx = i;
      const pct = idx / (N-1);
      const distKm = cumDist[idx] / 1000;
      const walk = WALKS.find(w => w.id === currentWalkId);
      ovTime.textContent = fmtTime(pointTime[idx]);
      pctDisp.textContent = Math.round(pct * 100) + '%';
      slider.value = Math.round(pct * 1000);
      ovDist.textContent = distKm.toFixed(2);
      let pace = '--';
      let si = idx;
      while (si > 0 && pointTime[idx] - pointTime[si] < 60) si--;
      if (si < idx) {
        const d = (cumDist[idx] - cumDist[si]) / 1000;
        const t = (pointTime[idx] - pointTime[si]) / 60;
        if (d > 0.01) pace = (t / d).toFixed(1);
      }
      ovPace.textContent = pace;
      if (walk) {
        ovSteps.textContent = Math.round(pct * walk.steps).toLocaleString();
        ovCal.textContent = Math.round(pct * walk.cal);
      }
      marker.setLatLng([gpxData[idx].lat, gpxData[idx].lon]);
      trailLine.setLatLngs(routeCoords.slice(0, idx + 1));
    }

    function tick() {
      if (!playing || !gpxData) return;
      const targetTime = animStartPoint + (Date.now() - animStartWall) / 1000 * speed;
      let lo = 0, hi = N - 1;
      while (lo < hi) { const mid = (lo + hi + 1) >> 1; if (pointTime[mid] <= targetTime) lo = mid; else hi = mid - 1; }
      draw(lo);
      if (idx >= N - 1) { playing = false; playBtn.textContent = '▶ Play'; clearInterval(timer); timer = null; }
    }

    function playFn() {
      if (!gpxData) return;
      if (idx >= N - 1) draw(0);
      animStartWall = Date.now(); animStartPoint = pointTime[idx];
      playing = true; playBtn.textContent = '⏸ Pause';
      if (timer) clearInterval(timer);
      timer = setInterval(tick, 50); tick();
    }
    function pause() { playing = false; playBtn.textContent = '▶ Play'; if (timer) { clearInterval(timer); timer = null; } }
    function resetAnim() { pause(); draw(0); }
    function setProgress(pct) { pause(); if (gpxData) draw(Math.round(pct / 100 * (N - 1))); }

    function buildSidebar() {
      WALKS.forEach(w => {
        const div = document.createElement('div');
        div.className = 'walk-item' + (w.hasGpx ? '' : ' no-gpx');
        div.dataset.id = w.id;
        const durM = Math.floor(w.dur / 60);
        const paceStr = w.dist > 0 ? (w.dur / 60 / w.dist).toFixed(1) + "'/km" : '';
        div.innerHTML = '<div class="dot ' + (w.hasGpx ? 'has' : 'none') + '"></div>' +
          '<div class="wi-body"><div class="wi-name">' + w.date + ' ' + w.time + ' · ' + w.type + '</div>' +
          '<div class="wi-meta"><span>⏱ ' + durM + 'm</span><span>👣 ' + w.steps.toLocaleString() + '</span><span>🔥 ' + w.cal + '</span>' +
          (w.avgHr ? '<span>🫀 ' + w.avgHr + '</span>' : '') +
          (paceStr ? '<span>🏃 ' + paceStr + '</span>' : '') +
          (!w.hasGpx ? '<span style="color:#444">(no GPS)</span>' : '') +
          '</div></div><div class="wi-dist">' + w.dist.toFixed(2) + '<span style="font-size:11px;color:#666">km</span></div>';
        if (w.hasGpx) div.addEventListener('click', () => loadWalk(w.id));
        walkList.appendChild(div);
      });
    }

    // Fix map sizing after layout settles
    setTimeout(() => {
      map.invalidateSize();
      if (currentWalkId && routeCoords) map.fitBounds(L.latLngBounds(routeCoords), { padding: [50, 50] });
    }, 500);
    window.addEventListener('resize', () => {
      map.invalidateSize();
      if (currentWalkId && routeCoords) map.fitBounds(L.latLngBounds(routeCoords), { padding: [50, 50] });
    });

    // Load data then init
    Promise.all([
      fetch('/data/walks.json').then(r => r.json()),
      fetch('/data/gpx.json').then(r => r.json())
    ]).then(([walksData, gpxData]) => {
      WALKS = walksData;
      GPX = gpxData;
      buildSidebar();
      const first = WALKS.find(w => w.hasGpx);
      if (first) loadWalk(first.id);
    });

    playBtn.addEventListener('click', () => playing ? pause() : playFn());
    resetBtn.addEventListener('click', resetAnim);
    slider.addEventListener('input', () => setProgress(parseInt(slider.value) / 10));
    document.querySelectorAll('.speed-btn').forEach(b => b.addEventListener('click', () => {
      document.querySelectorAll('.speed-btn').forEach(x => x.classList.remove('active'));
      b.classList.add('active');
      if (playing) { animStartWall = Date.now(); animStartPoint = pointTime[idx]; }
      speed = parseFloat(b.dataset.speed);
    }));
    document.addEventListener('keydown', e => {
      if (e.key === ' ' || e.key === 'k') { e.preventDefault(); playing ? pause() : playFn(); }
      if (e.key === 'r') resetAnim();
    });

    // ---- Tab switching ----
    document.querySelectorAll('.fit-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.fit-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
        if (tab.dataset.tab === 'walks') setTimeout(() => map.invalidateSize(), 50);
        if (tab.dataset.tab === 'dashboard') setTimeout(() => initCharts(), 50);
      });
    });

    document.querySelectorAll('.dash-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.dash-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.dash-content').forEach(c => c.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById('dash-' + tab.dataset.dtab).classList.add('active');
        setTimeout(() => initCharts(), 50);
      });
    });
    // Activate first dash tab by default
    document.querySelector('.dash-tab')?.classList.add('active');
    document.querySelector('.dash-content')?.classList.add('active');

    // ---- Dashboard ----
    let DASH = null;
    let charts = {};
    function destroyCharts() {
      Object.values(charts).forEach(c => c.destroy());
      charts = {};
    }
    function initCharts() {
      if (!DASH) return;
      destroyCharts();
      // Sleep chart
      const sc = document.getElementById('chart-sleep');
      if (sc) {
        const sleep = DASH.sleep.daily.slice(-14);
        charts.sleep = new Chart(sc, {
          type: 'bar',
          data: {
            labels: sleep.map(s => s.date.slice(5)),
            datasets: [
              { label: 'Deep', data: sleep.map(s => Math.round(s.deep_min / 60 * 10) / 10), backgroundColor: '#4a90d9', stack: 'sleep' },
              { label: 'Light', data: sleep.map(s => Math.round(s.light_min / 60 * 10) / 10), backgroundColor: '#87ceeb', stack: 'sleep' },
              { label: 'REM', data: sleep.map(s => Math.round(s.rem_min / 60 * 10) / 10), backgroundColor: '#9b59b6', stack: 'sleep' },
              { label: 'Awake', data: sleep.map(s => Math.round(s.awake_min / 60 * 10) / 10), backgroundColor: '#e74c3c', stack: 'sleep' },
            ]
          },
          options: { responsive: true, maintainAspectRatio: false, scales: { x: { stacked: true }, y: { stacked: true, title: { display: true, text: 'Hours' } } }, plugins: { legend: { labels: { color: '#aaa' } } } }
        });
      }
      // Resting HR
      const rc = document.getElementById('chart-resting-hr');
      if (rc) {
        const hr = DASH.heart_rate.resting.slice(-14);
        charts.resting = new Chart(rc, {
          type: 'line',
          data: { labels: hr.map(h => h.date.slice(5)), datasets: [{ label: 'Resting HR', data: hr.map(h => h.bpm), borderColor: '#ff6b6b', backgroundColor: '#ff6b6b20', fill: true, tension: 0.3 }] },
          options: { responsive: true, maintainAspectRatio: false, scales: { y: { min: 35, max: 70 } }, plugins: { legend: { labels: { color: '#aaa' } } } }
        });
      }
      // HRV
      const hc = document.getElementById('chart-hrv');
      if (hc) {
        const sleep = DASH.sleep.daily.slice(-14).filter(s => s.hrv_median > 0);
        charts.hrv = new Chart(hc, {
          type: 'line',
          data: { labels: sleep.map(s => s.date.slice(5)), datasets: [{ label: 'HRV Median', data: sleep.map(s => s.hrv_median), borderColor: '#4caf50', backgroundColor: '#4caf5020', fill: true, tension: 0.3 }] },
          options: { responsive: true, maintainAspectRatio: false, scales: { y: { min: 0, max: 120 } }, plugins: { legend: { labels: { color: '#aaa' } } } }
        });
      }
      // Steps
      const stc = document.getElementById('chart-steps');
      if (stc) {
        const steps = DASH.activity.steps.slice(-14);
        charts.steps = new Chart(stc, {
          type: 'bar',
          data: { labels: steps.map(s => s.date.slice(5)), datasets: [{ label: 'Steps', data: steps.map(s => s.total_steps || 0), backgroundColor: '#4fc3f7' }] },
          options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { labels: { color: '#aaa' } } } }
        });
      }
      // Calories
      const cc = document.getElementById('chart-calories');
      if (cc) {
        const cal = DASH.activity.calories.slice(-14);
        charts.calories = new Chart(cc, {
          type: 'bar',
          data: { labels: cal.map(c => c.date.slice(5)), datasets: [{ label: 'Calories', data: cal.map(c => c.total_calories || 0), backgroundColor: '#ff9800' }] },
          options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { labels: { color: '#aaa' } } } }
        });
      }
      // SpO2
      const spc = document.getElementById('chart-spo2');
      if (spc) {
        const spo2 = DASH.health.spo2.slice(-14);
        charts.spo2 = new Chart(spc, {
          type: 'line',
          data: { labels: spo2.map(s => s.date.slice(5)), datasets: [{ label: 'SpO2 %', data: spo2.map(s => s.avg_spo2 || s.value || 0), borderColor: '#00bcd4', backgroundColor: '#00bcd420', fill: true, tension: 0.3 }] },
          options: { responsive: true, maintainAspectRatio: false, scales: { y: { min: 90, max: 100 } }, plugins: { legend: { labels: { color: '#aaa' } } } }
        });
      }
      // Stress
      const strc = document.getElementById('chart-stress');
      if (strc) {
        const stress = DASH.health.stress.slice(-14);
        charts.stress = new Chart(strc, {
          type: 'line',
          data: { labels: stress.map(s => s.date.slice(5)), datasets: [{ label: 'Stress', data: stress.map(s => s.avg_stress || s.value || 0), borderColor: '#ff5722', backgroundColor: '#ff572220', fill: true, tension: 0.3 }] },
          options: { responsive: true, maintainAspectRatio: false, scales: { y: { min: 0, max: 100 } }, plugins: { legend: { labels: { color: '#aaa' } } } }
        });
      }
    }
    fetch('/data/dashboard.json').then(r => r.json()).then(data => {
      DASH = data;
      renderOverview();
      renderSleep();
      renderHeart();
      renderActivity();
      renderHealth();
    });

    function el(tag, cls, html) {
      const e = document.createElement(tag);
      if (cls) e.className = cls;
      if (html) e.innerHTML = html;
      return e;
    }

    function fmtHrs(mins) {
      const h = Math.floor(mins / 60);
      const m = mins % 60;
      return h + 'h ' + (m < 10 ? '0' : '') + m + 'm';
    }

    function renderOverview() {
      const c = document.getElementById('dash-overview');
      const sleep = DASH.sleep.daily;
      const latest = sleep[sleep.length - 1];
      const steps = DASH.activity.steps;
      const latestSteps = steps[steps.length - 1];
      const hr = DASH.heart_rate.resting;
      const latestHR = hr[hr.length - 1];

      let html = '<div class="dash-grid">';
      html += '<div class="dash-card"><h3>Last Night Sleep</h3><div class="val">' + (latest ? fmtHrs(latest.deep_min + latest.light_min + latest.rem_min) : '--') + '</div><div class="sub">' + (latest ? latest.efficiency + '% efficiency' : '') + '</div></div>';
      html += '<div class="dash-card"><h3>Steps Today</h3><div class="val">' + (latestSteps ? latestSteps.total_steps?.toLocaleString() || '--' : '--') + '</div><div class="sub">' + (latestSteps ? 'Goal: ' + (latestSteps.goal_steps || '--') : '') + '</div></div>';
      html += '<div class="dash-card"><h3>Resting HR</h3><div class="val">' + (latestHR ? latestHR.bpm + ' bpm' : '--') + '</div><div class="sub">7-day avg: ' + (hr.length ? Math.round(hr.slice(-7).reduce((a,b) => a + b.bpm, 0) / Math.min(7, hr.length)) + ' bpm' : '--') + '</div></div>';
      html += '<div class="dash-card"><h3>HRV (Sleep)</h3><div class="val">' + (latest ? latest.hrv_median + ' ms' : '--') + '</div><div class="sub">' + (latest ? 'Std: ' + latest.hrv_std + ' ms' : '') + '</div></div>';
      html += '</div>';
      c.innerHTML = html;
    }

    function renderSleep() {
      const c = document.getElementById('dash-sleep');
      const sleep = DASH.sleep.daily;
      if (!sleep.length) { c.innerHTML = '<p style="color:#666">No sleep data</p>'; return; }

      let html = '<div class="dash-card"><h3>Sleep Duration (Last 14 Days)</h3><div class="dash-chart-lg" id="chart-sleep"></div></div>';
      html += '<div class="dash-card"><h3>Sleep Stages</h3>';
      sleep.slice(-7).reverse().forEach(s => {
        const total = s.deep_min + s.light_min + s.rem_min + s.awake_min;
        const dp = total > 0 ? Math.round(s.deep_min / total * 100) : 0;
        const lp = total > 0 ? Math.round(s.light_min / total * 100) : 0;
        const rp = total > 0 ? Math.round(s.rem_min / total * 100) : 0;
        const ap = total > 0 ? Math.round(s.awake_min / total * 100) : 0;
        html += '<div style="margin-bottom:12px">';
        html += '<div style="display:flex;justify-content:space-between;font-size:11px;color:#888;margin-bottom:4px"><span>' + s.date + '</span><span>' + fmtHrs(s.deep_min + s.light_min + s.rem_min) + ' · ' + s.efficiency + '%</span></div>';
        html += '<div class="sleep-bar"><div class="sleep-deep" style="width:' + dp + '%"></div><div class="sleep-light" style="width:' + lp + '%"></div><div class="sleep-rem" style="width:' + rp + '%"></div><div class="sleep-awake" style="width:' + ap + '%"></div></div>';
        html += '<div class="sleep-timeline"><span>Deep ' + fmtHrs(s.deep_min) + '</span><span>Light ' + fmtHrs(s.light_min) + '</span><span>REM ' + fmtHrs(s.rem_min) + '</span><span>Awake ' + fmtHrs(s.awake_min) + '</span></div>';
        html += '</div>';
      });
      html += '</div>';
      c.innerHTML = html;
    }

    function renderHeart() {
      const c = document.getElementById('dash-heart');
      const resting = DASH.heart_rate.resting;
      if (!resting.length) { c.innerHTML = '<p style="color:#666">No heart rate data</p>'; return; }

      let html = '<div class="dash-card"><h3>Resting Heart Rate (bpm)</h3><div class="dash-chart" id="chart-resting-hr"></div></div>';
      html += '<div class="dash-card"><h3>HRV During Sleep (ms)</h3><div class="dash-chart" id="chart-hrv"></div></div>';
      html += '<div class="dash-card"><h3>Recent Readings</h3>';
      resting.slice(-7).reverse().forEach(r => {
        html += '<div class="stat-row"><span class="lbl">' + r.date + '</span><span class="val">' + r.bpm + ' bpm</span></div>';
      });
      html += '</div>';
      c.innerHTML = html;
    }

    function renderActivity() {
      const c = document.getElementById('dash-activity');
      const steps = DASH.activity.steps;
      const calories = DASH.activity.calories;
      if (!steps.length) { c.innerHTML = '<p style="color:#666">No activity data</p>'; return; }

      let html = '<div class="dash-card"><h3>Daily Steps</h3><div class="dash-chart" id="chart-steps"></div></div>';
      html += '<div class="dash-card"><h3>Daily Calories</h3><div class="dash-chart" id="chart-calories"></div></div>';
      html += '<div class="dash-card"><h3>Recent Activity</h3>';
      steps.slice(-7).reverse().forEach(s => {
        html += '<div class="stat-row"><span class="lbl">' + s.date + '</span><span class="val">' + (s.total_steps || 0).toLocaleString() + ' steps</span></div>';
      });
      html += '</div>';
      c.innerHTML = html;
    }

    function renderHealth() {
      const c = document.getElementById('dash-health');
      const spo2 = DASH.health.spo2;
      const stress = DASH.health.stress;

      let html = '<div class="dash-card"><h3>Blood Oxygen (SpO2 %)</h3><div class="dash-chart" id="chart-spo2"></div></div>';
      html += '<div class="dash-card"><h3>Stress Level</h3><div class="dash-chart" id="chart-stress"></div></div>';
      html += '<div class="dash-card"><h3>Health Summary</h3>';
      if (spo2.length) {
        const latest = spo2[spo2.length - 1];
        html += '<div class="stat-row"><span class="lbl">SpO2 (latest)</span><span class="val">' + (latest.avg_spo2 || latest.value || '--') + '%</span></div>';
      }
      if (stress.length) {
        const latest = stress[stress.length - 1];
        html += '<div class="stat-row"><span class="lbl">Stress (latest)</span><span class="val">' + (latest.avg_stress || latest.value || '--') + '</span></div>';
      }
      html += '</div>';
      c.innerHTML = html;
    }
  </script>
</BaseLayout>
