---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} | Projects`} description={project.data.description} activePage="projects">
  <div class="project-detail container">
    <a href="/projects" class="back-link">&larr; All projects</a>
    <h1>{project.data.title}</h1>

    {project.data.video && (
      <div class="video-stage">
        <div class="video-hero">
          <video controls muted playsinline id="project-video" onended="this.style.opacity='0.5'">
            <source src={project.data.video} type="video/mp4" />
          </video>
        </div>
      </div>
    )}
  </div>
</BaseLayout>


