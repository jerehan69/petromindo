---
import BaseLayout from "../../layouts/BaseLayout.astro";

const sheetUrl = "https://docs.google.com/spreadsheets/d/1s2cu53HMW7QClMiPpajXUQTQ4aGI9uWlCMwwb9_nxwQ/edit";
---

<BaseLayout title="API Cost Comparison | Projects" description="Live AI model cost tracking — OpenCode Go vs DeepSeek Official API, with OpenRouter market comparison." activePage="projects">
  <div class="project-detail container">
    <a href="/projects" class="back-link">&larr; All projects</a>
    <h1>API Cost Comparison</h1>

    <p style="color: var(--muted); margin-bottom: 2rem; font-size: 1.05rem;">
      Tracking AI model costs across OpenCode Go, DeepSeek Official API, and the OpenRouter marketplace — because you can't optimise what you don't measure.
    </p>

    <!-- Quick Links -->
    <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.5rem;">
      <a href={sheetUrl} target="_blank" style="display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.6rem 1.2rem; background: var(--accent); color: #fff; border-radius: 8px; font-weight: 600; font-size: 0.9rem;">
        📊 Open Live Sheet &rarr;
      </a>
      <a href="https://openrouter.ai/models?order=most-popular" target="_blank" style="display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.6rem 1.2rem; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; font-weight: 500; font-size: 0.9rem;">
        🔍 View on OpenRouter &rarr;
      </a>
    </div>

    <!-- Charts Section -->
    <h2 style="font-size: 1.3rem; font-weight: 600; margin-bottom: 1rem;">Output Cost Comparison: Chinese vs American Models</h2>
    <p style="color: var(--muted); font-size: 0.85rem; margin-bottom: 1.5rem;">
      Top 10 most popular models on OpenRouter · Output cost per 1M tokens · Sorted highest &rarr; lowest
    </p>

    <div class="chart-grid">
      <div class="chart-card">
        <h3 class="chart-title cn">🇨🇳 Chinese</h3>
        <canvas id="chartCn"></canvas>
        <p class="chart-footer">DeepSeek · Xiaomi · MiniMax · Tencent · Z.ai · StepFun · MoonshotAI</p>
      </div>
      <div class="chart-card">
        <h3 class="chart-title us">🇺🇸 American</h3>
        <canvas id="chartUs"></canvas>
        <p class="chart-footer">Anthropic · OpenAI · Google · xAI · Meta</p>
        <p class="vs-legend">Multiples vs DeepSeek V4 Flash ($0.18)</p>
      </div>
    </div>

    <!-- Pricing Tables -->
    <h2 style="font-size: 1.3rem; font-weight: 600; margin: 2.5rem 0 1rem;">Pricing at a Glance</h2>

    <h3 style="font-size: 1.05rem; font-weight: 600; margin: 1.5rem 0 0.5rem; color: var(--accent);">OpenCode Go</h3>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Plan</th><th>First Month</th><th>After</th><th>Usage Limits</th></tr></thead>
        <tbody>
          <tr><td><strong>Go</strong></td><td><strong>$5</strong></td><td><strong>$10/mo</strong></td><td>$12/5h · $30/wk · $60/mo</td></tr>
        </tbody>
      </table>
    </div>

    <p style="color: var(--muted); font-size: 0.85rem; margin: 0.75rem 0;">
      Includes GLM-5.2, Kimi K2.7 Code, DeepSeek V4 Flash/Pro, Qwen3.7 Max, and 8+ other models bundled into the monthly pool. Usage drawn from the $60 monthly cap — cheaper models like V4 Flash get ~31,650 requests per 5h window.
    </p>

    <h3 style="font-size: 1.05rem; font-weight: 600; margin: 1.5rem 0 0.5rem; color: var(--accent);">DeepSeek Official API</h3>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Model</th><th>Input (cache miss)</th><th>Input (cache hit)</th><th>Output</th><th>Context</th><th>Max Output</th></tr></thead>
        <tbody>
          <tr><td><strong>deepseek-v4-flash</strong></td><td>$0.14 / 1M</td><td>$0.0028 / 1M</td><td><strong>$0.28 / 1M</strong></td><td>1,048,576</td><td>384K</td></tr>
          <tr><td><strong>deepseek-v4-pro</strong></td><td>$0.435 / 1M</td><td>$0.003625 / 1M</td><td><strong>$0.87 / 1M</strong></td><td>1,048,576</td><td>384K</td></tr>
        </tbody>
      </table>
    </div>

    <p style="color: var(--muted); font-size: 0.85rem; margin: 0.75rem 0;">
      Concurrency: 2,500 (Flash) · 500 (Pro). Deprecated aliases <code>deepseek-chat</code> and <code>deepseek-reasoner</code> retire 2026-07-24. V4 Pro's 75% discount is now permanent.
    </p>

    <!-- Usage Tracking -->
    <h2 style="font-size: 1.3rem; font-weight: 600; margin: 2.5rem 0 1rem;">Usage Log (Latest Snapshot)</h2>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
      <div class="stat-card" style="border-left: 3px solid #e74c3c;">
        <div style="font-size: 0.75rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em;">OpenCode Go</div>
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.5rem; margin-top: 0.5rem;">
          <div><div style="font-size: 0.7rem; color: var(--muted);">Rolling</div><div style="font-weight: 700;">2%</div><div style="font-size: 0.7rem; color: var(--muted);">resets 3.5h</div></div>
          <div><div style="font-size: 0.7rem; color: var(--muted);">Weekly</div><div style="font-weight: 700; color: #e74c3c;">99%</div><div style="font-size: 0.7rem; color: var(--muted);">resets 2.5d</div></div>
          <div><div style="font-size: 0.7rem; color: var(--muted);">Monthly</div><div style="font-weight: 700;">72%</div><div style="font-size: 0.7rem; color: var(--muted);">resets 8d</div></div>
        </div>
      </div>
      <div class="stat-card" style="border-left: 3px solid #3498db;">
        <div style="font-size: 0.75rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em;">DeepSeek API (June)</div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-top: 0.5rem;">
          <div><div style="font-size: 0.7rem; color: var(--muted);">V4 Flash</div><div style="font-weight: 700;">1,599 req</div><div style="font-size: 0.7rem; color: var(--muted);">68.8M tokens</div></div>
          <div><div style="font-size: 0.7rem; color: var(--muted);">V4 Pro</div><div style="font-weight: 700;">665 req</div><div style="font-size: 0.7rem; color: var(--muted);">47.5M tokens</div></div>
        </div>
        <div style="margin-top: 0.4rem; font-size: 0.8rem; color: var(--muted);">Balance: <strong>$0.00</strong> · June spend: <strong>¥9.52</strong></div>
      </div>
    </div>

    <p style="color: var(--muted); font-size: 0.85rem;">
      Usage snapshots captured on-demand via browser automation. <a href={sheetUrl} target="_blank">Full history in the sheet</a>.
    </p>
  </div>
</BaseLayout>

<script>
import Chart from 'chart.js/auto';

(function() {
  const FLASH_PRICE = 0.18;

  const labelPlugin = {
    id: 'barLabels',
    afterDraw(chart) {
      const ctx = chart.ctx;
      chart.data.datasets.forEach((ds, dsIdx) => {
        const meta = chart.getDatasetMeta(dsIdx);
        meta.data.forEach((bar, idx) => {
          const val = ds.data[idx];
          const mult = (val / FLASH_PRICE).toFixed(val >= 10 ? 0 : 1);
          const x = bar.x + 6;
          const y = bar.y + bar.height / 2;
          ctx.save();
          ctx.fillStyle = '#999';
          ctx.font = 'bold 10px Inter, system-ui, sans-serif';
          ctx.textAlign = 'left';
          ctx.textBaseline = 'middle';
          ctx.fillText(mult + 'x', x, y);
          ctx.restore();
        });
      });
    }
  };

  function makeChart(id, data, colors, opts) {
    const el = document.getElementById(id);
    if (!el) return;
    opts = opts || {};
    new Chart(el, {
      type: 'bar',
      plugins: opts.showLabels ? [labelPlugin] : [],
      data: {
        labels: data.map(d => d.label),
        datasets: [{
          data: data.map(d => d.value),
          backgroundColor: colors,
          borderColor: 'transparent',
          borderRadius: 4,
          borderSkipped: false,
        }]
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: ctx => '$' + ctx.raw + ' / 1M output tokens'
            }
          }
        },
        scales: {
          x: {
            title: opts.xTitle ? { display: true, text: opts.xTitle, color: '#8a7e72', font: { size: 10 } } : { display: false },
            grid: { color: 'rgba(224, 216, 208, 0.3)' },
            max: opts.maxX || undefined,
            ticks: { color: '#8a7e72', font: { size: 10 }, callback: v => '$' + v }
          },
          y: {
            grid: { display: false },
            ticks: { color: '#1a1a1a', font: { size: 11, weight: '500' } }
          }
        }
      }
    });
  }

  const cnColors = ['#c0392b','#e74c3c','#e67e22','#f39c12','#27ae60','#2ecc71','#1abc9c','#16a085','#3498db','#2980b9'];
  const usColor = '#777777';

  const cnData = [
    {label:'Kimi K2.6', value:3.41},
    {label:'GLM 5.2', value:3.00},
    {label:'MiniMax M3', value:1.20},
    {label:'Step 3.7 Flash', value:1.15},
    {label:'DeepSeek V4 Pro', value:0.87},
    {label:'MiMo-V2.5-Pro', value:0.87},
    {label:'DeepSeek V3.2', value:0.34},
    {label:'MiMo-V2.5', value:0.28},
    {label:'Hy3 preview', value:0.21},
    {label:'DeepSeek V4 Flash', value:0.18}
  ];

  const usData = [
    {label:'GPT-5.5', value:30},
    {label:'Claude Opus 4.7', value:25},
    {label:'Claude Opus 4.8', value:25},
    {label:'Claude Sonnet 4.6', value:15},
    {label:'GPT-5.4', value:15},
    {label:'Gemini 3.5 Flash', value:9},
    {label:'Gemini 3 Flash Preview', value:3},
    {label:'Gemini 2.5 Flash', value:2.50},
    {label:'GPT-4o-mini', value:0.60},
    {label:'Gemini 2.5 Flash Lite', value:0.40}
  ];

  makeChart('chartCn', cnData, cnColors, { xTitle: '$ / 1M output tokens' });
  makeChart('chartUs', usData, Array(10).fill(usColor), { xTitle: '$ / 1M output tokens', showLabels: true, maxX: 38 });
})();
</script>

<style>
  .chart-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .chart-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1rem 0.75rem;
  }

  .chart-title {
    text-align: center;
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border);
  }
  .chart-title.cn { border-color: #e74c3c; }
  .chart-title.us { border-color: #3498db; }

  .chart-card {
    height: 430px;
  }

  .chart-card canvas {
    height: 320px !important;
    width: 100% !important;
  }

  .chart-footer {
    text-align: center;
    font-size: 0.7rem;
    color: var(--muted);
    margin-top: 0.65rem;
    padding-top: 0;
  }

  .vs-legend {
    text-align: center;
    font-size: 0.65rem;
    color: #999;
    margin-top: 0.15rem;
    font-style: italic;
  }

  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 8px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }

  thead {
    background: var(--surface);
  }

  th {
    padding: 0.65rem 1rem;
    text-align: left;
    font-weight: 600;
    border-bottom: 2px solid var(--border);
    white-space: nowrap;
  }

  td {
    padding: 0.55rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  tbody tr:last-child td {
    border-bottom: none;
  }

  tbody tr:hover {
    background: rgba(230, 81, 0, 0.04);
  }

  .stat-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
  }
</style>
