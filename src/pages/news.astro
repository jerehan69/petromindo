---
import BaseLayout from "../layouts/BaseLayout.astro";

const SHEET_ID = import.meta.env.SHEET_ID;

interface Article {
  companies: string;
  country: string;
  date: string;
  time: string;
  content: string;
  account: string;
  username: string;
  likes: string;
  retweets: string;
  replies: string;
  views: string;
  url: string;
}

const KEYWORDS = ["oil", "gas", "lng", "energy", "coal"];

const COUNTRY_NAMES = new Set(["CHINA", "IRAN", "JAPAN", "KOREA", "QATAR", "UK", "USA"]);

// S&P 500 tickers + common non-S&P tickers seen in the feed
const TICKERS = new Set([
  "A","AAPL","ABBV","ABNB","ABT","ACGL","ACN","ADBE","ADI","ADM","ADP","ADSK","AEE","AEP","AES","AFL",
  "AGCO","AGI","AIG","AIZ","AJG","AKAM","ALB","ALGN","ALK","ALL","ALLE","AMAT","AMCR","AMD","AME",
  "AMGN","AMP","AMT","AMZN","ANET","ANSS","AON","AOS","APA","APD","APH","APO","APP","APTV","ARE",
  "ARES","ATO","AVB","AVGO","AVY","AWK","AXON","AXP","AZO","BA","BAC","BALL","BAX","BBY","BDX",
  "BEN","BG","BIIB","BIO","BK","BKNG","BKR","BLDR","BLK","BMY","BR","BSX","BWA","BX","BXP","C",
  "CAG","CAH","CARR","CAT","CB","CBOE","CBRE","CCL","CDNS","CDW","CE","CEG","CF","CFG","CHD",
  "CHRW","CHTR","CI","CINF","CL","CLX","CMCSA","CME","CMG","CMI","CMS","CNC","CNP","COF","COIN",
  "COST","CPAY","CPB","CPRT","CPT","CRL","CRM","CRWD","CSCO","CSGP","CSX","CTAS","CTLT","CTRA",
  "CTSH","CTVA","CVS","CVX","CZR","D","DAL","DAY","DBX","DD","DDOG","DE","DECK","DELL","DFS",
  "DG","DGX","DHI","DHR","DIS","DLR","DLTR","DOC","DOCU","DOV","DOW","DPZ","DRI","DT","DTE",
  "DUK","DVA","DVN","DXC","DXCM","EA","EBAY","ECL","ED","EFX","EG","EIX","EL","ELV","EME",
  "EMN","EMR","ENPH","EOG","EPAM","EQIX","EQR","EQT","ERIE","ES","ESS","ETN","ETR","ETSY","EVRG",
  "EW","EXC","EXPD","EXPE","EXR","F","FANG","FAST","FCX","FDS","FDX","FE","FFIV","FI","FICO",
  "FIS","FITB","FMC","FOX","FOXA","FRT","FSLR","FTNT","FTV","GD","GE","GEHC","GEN","GFS","GGG",
  "GILD","GIS","GLW","GM","GNRC","GOOG","GOOGL","GPC","GPN","GRMN","GS","GWW","HAL","HAS",
  "HBAN","HCA","HD","HES","HIG","HII","HLT","HOLX","HON","HPE","HPQ","HRL","HSIC","HST","HSY",
  "HUBB","HUM","HWM","IBM","ICE","IDXX","IEX","IFF","ILMN","INCY","INTC","INTU","INVH","IP","IPG",
  "IQV","IR","IRM","ISRG","IT","ITW","IVZ","J","JBHT","JBL","JCI","JKHY","JNJ","JNPR","JPM",
  "K","KDP","KEY","KEYS","KHC","KIM","KKR","KLAC","KMB","KMI","KMX","KO","KR","L","LDOS","LEN",
  "LH","LHX","LIN","LKQ","LLY","LMT","LNG","LNT","LOW","LPLA","LRCX","LSXMA","LSXMK","LULU","LUV",
  "LVS","LW","LYB","LYV","MA","MAA","MANH","MAR","MAS","MAT","MCD","MCHP","MCK","MCO","MDLZ","MDT",
  "MET","META","MGM","MHK","MKC","MKTX","MLM","MMC","MMM","MNST","MO","MOH","MOS","MPC","MPWR",
  "MRK","MRNA","MRO","MS","MSCI","MSFT","MSI","MTB","MTCH","MTD","MU","NDAQ","NDSN","NEE","NEM",
  "NFLX","NI","NKE","NOC","NOW","NRG","NSC","NTAP","NTRS","NUE","NVDA","NVR","NWS","NWSA","NXPI",
  "O","OC","ODFL","OGE","OKE","OMC","ON","ORCL","ORLY","OTIS","OXY","PANW","PARA","PAYX","PCAR",
  "PCG","PEG","PEP","PFE","PFG","PG","PGR","PH","PHM","PINS","PKG","PLD","PLTR","PM","PNC","PNR",
  "PODD","POOL","PPG","PPL","PRU","PSA","PSX","PTC","PWR","PYPL","QCOM","RCL","REG","REGN","RF",
  "RGA","RHI","RJF","RL","RMD","ROK","ROL","ROP","ROST","RPM","RS","RSG","RTX","RVTY","SBAC",
  "SBUX","SCHW","SHW","SIRI","SJM","SLB","SLG","SNA","SNAP","SNPS","SO","SOLV","SPG","SPGI","SRE",
  "STE","STLD","STT","STX","STZ","SWK","SWKS","SYF","SYK","SYY","T","TAP","TDG","TDY","TECH",
  "TEL","TER","TFC","TFX","TGT","TJX","TMO","TMUS","TPR","TRGP","TRMB","TROW","TRV","TSCO","TSLA",
  "TSN","TT","TTD","TTWO","TWLO","TXN","TXT","TYL","UBER","UDR","UHS","ULTA","UNH","UNM","UNP",
  "UPS","URI","USB","V","VICI","VLO","VMC","VRSK","VRSN","VRTX","VST","VTR","VTRS","VZ","WAB",
  "WAL","WAT","WBA","WBD","WCC","WDC","WEC","WELL","WFC","WHR","WM","WMB","WMS","WMT","WRB",
  "WRK","WSM","WSO","WST","WTW","WY","WYNN","XEL","XOM","XYL","YUM","Z","ZBH","ZBRA","ZION","ZTS",
  // Non-S&P tickers seen in the feed
  "SPACEX","DEEPSEEK","OPENAI","BLDP","NVO","NOVO NORDISK",
]);

// Company names to look for in content when Companies column is empty/filtered
function filterCompanies(val: string, content?: string): string {
  if (!val && !content) return "";
  // Start from the sheet value, filter out countries
  let result = (val || "").split(", ").filter(c => !COUNTRY_NAMES.has(c)).map(c => {
    if (TICKERS.has(c)) return c;
    if (c === c.toUpperCase() && c.length <= 5) return c;
    return c.charAt(0).toUpperCase() + c.slice(1).toLowerCase();
  }).filter(Boolean).join(", ");
  // If empty after filtering, try extracting from content
  if (!result && content) {
    result = extractFromContent(content);
  }
  return result;
}

function extractFromContent(content: string): string {
  // Check for $TICKER patterns
  const tickerMatch = content.match(/\$([A-Z]{1,5})\b/g);
  if (tickerMatch) {
    const tickers = tickerMatch.map(t => t.slice(1)).filter(t => TICKERS.has(t));
    if (tickers.length > 0) return tickers.join(", ");
  }
  // Check for known company names
  if (/NOVO\s+NORDISK/i.test(content)) return "Novo Nordisk";
  if (/\bDEEPSEEK\b/i.test(content)) return "DeepSeek";
  if (/\bSPACEX\b/i.test(content)) return "SpaceX";
  if (/\bOPENAI\b/i.test(content)) return "OpenAI";
  if (/QATARENERGY/i.test(content)) return "QatarEnergy";
  return "";
}

function hasKeyword(article: Article): boolean {
  const text = (article.content + " " + article.companies).toLowerCase();
  return KEYWORDS.some((kw) => text.includes(kw));
}

function isTrumpStory(article: Article): boolean {
  return article.content.toLowerCase().includes("trump");
}

function formatTime(time: string): string {
  if (!time) return "";
  return time.substring(0, 5);
}

async function fetchSheet(): Promise<Article[]> {
  const tokenResp = await fetch("https://oauth2.googleapis.com/token", {
    method: "POST",
    body: new URLSearchParams({
      client_id: import.meta.env.GOOGLE_CLIENT_ID,
      client_secret: import.meta.env.GOOGLE_CLIENT_SECRET,
      refresh_token: import.meta.env.GOOGLE_REFRESH_TOKEN,
      grant_type: "refresh_token",
    }),
  });
  const { access_token } = await tokenResp.json();

  const resp = await fetch(
    `https://sheets.googleapis.com/v4/spreadsheets/${SHEET_ID}/values/Feed?valueRenderOption=FORMULA&majorDimension=ROWS`,
    { headers: { Authorization: `Bearer ${access_token}` } }
  );
  const data = await resp.json();
  const rows: string[][] = data.values || [];

  const articles: Article[] = [];
  for (let i = 1; i < rows.length; i++) {
    const r = rows[i];
    if (r.length < 12) continue;
    articles.push({
      companies: filterCompanies(r[0] || "", r[4] || ""),
      country: r[1] || "",
      date: r[2] || "",
      time: r[3] || "",
      content: r[4] || "",
      account: r[5] || "",
      username: r[6] || "",
      likes: r[7] || "",
      retweets: r[8] || "",
      replies: r[9] || "",
      views: r[10] || "",
      url: r[11] || "",
    });
  }

  return articles;
}

let initialArticles: Article[] = [];
try {
  initialArticles = await fetchSheet();
} catch (e) {
  console.error("Build-time sheet fetch failed:", e);
}
---

<BaseLayout title="News Feed" description="Curated market & news feed.">
  <div class="sheet-container">
    <div class="stats-row">
      <span class="stats-count" id="stats-count">{initialArticles.length} posts</span>
      <span class="stats-indicator" id="live-indicator">● live</span>
    </div>

    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th class="col-date">Date</th>
            <th>Time</th>
            <th class="col-title">Content</th>
            <th>Companies</th>
            <th>Country</th>
            <th class="col-source">Source</th>
          </tr>
        </thead>
        <tbody id="news-body">
          {initialArticles.map((article, idx) => {
            const hl = isTrumpStory(article) ? "hl-red" : hasKeyword(article) ? "hl-yellow" : "";
            const rowClass = hl || (idx % 2 === 1 ? "alt" : "");
            return (
            <tr class={rowClass}>
              <td class="cell-date">{article.date}</td>
              <td class="cell-time">{formatTime(article.time)}</td>
              <td class="cell-title">
                {article.url ? (
                  <a href={article.url} target="_blank" rel="noopener" class="title-link">{article.content}</a>
                ) : (
                  <span class="title-text">{article.content}</span>
                )}
              </td>
              <td class="cell-company">{article.companies || ""}</td>
              <td class="cell-country">{article.country || ""}</td>
              <td class="cell-source">{article.account || article.username || ""}</td>
            </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>

<script>
const KEYWORDS = ["oil", "gas", "lng", "energy", "coal"];
const COUNTRY_NAMES = new Set(["CHINA", "IRAN", "JAPAN", "KOREA", "QATAR", "UK", "USA"]);
const TICKERS = new Set(["A","AAPL","ABBV","ABNB","ABT","ACGL","ACN","ADBE","ADI","ADM","ADP","ADSK","AEE","AEP","AES","AFL","AGCO","AGI","AIG","AIZ","AJG","AKAM","ALB","ALGN","ALK","ALL","ALLE","AMAT","AMCR","AMD","AME","AMGN","AMP","AMT","AMZN","ANET","ANSS","AON","AOS","APA","APD","APH","APO","APP","APTV","ARE","ARES","ATO","AVB","AVGO","AVY","AWK","AXON","AXP","AZO","BA","BAC","BALL","BAX","BBY","BDX","BEN","BG","BIIB","BIO","BK","BKNG","BKR","BLDR","BLK","BMY","BR","BSX","BWA","BX","BXP","C","CAG","CAH","CARR","CAT","CB","CBOE","CBRE","CCL","CDNS","CDW","CE","CEG","CF","CFG","CHD","CHRW","CHTR","CI","CINF","CL","CLX","CMCSA","CME","CMG","CMI","CMS","CNC","CNP","COF","COIN","COST","CPAY","CPB","CPRT","CPT","CRL","CRM","CRWD","CSCO","CSGP","CSX","CTAS","CTLT","CTRA","CTSH","CTVA","CVS","CVX","CZR","D","DAL","DAY","DBX","DD","DDOG","DE","DECK","DELL","DFS","DG","DGX","DHI","DHR","DIS","DLR","DLTR","DOC","DOCU","DOV","DOW","DPZ","DRI","DT","DTE","DUK","DVA","DVN","DXC","DXCM","EA","EBAY","ECL","ED","EFX","EG","EIX","EL","ELV","EME","EMN","EMR","ENPH","EOG","EPAM","EQIX","EQR","EQT","ERIE","ES","ESS","ETN","ETR","ETSY","EVRG","EW","EXC","EXPD","EXPE","EXR","F","FANG","FAST","FCX","FDS","FDX","FE","FFIV","FI","FICO","FIS","FITB","FMC","FOX","FOXA","FRT","FSLR","FTNT","FTV","GD","GE","GEHC","GEN","GFS","GGG","GILD","GIS","GLW","GM","GNRC","GOOG","GOOGL","GPC","GPN","GRMN","GS","GWW","HAL","HAS","HBAN","HCA","HD","HES","HIG","HII","HLT","HOLX","HON","HPE","HPQ","HRL","HSIC","HST","HSY","HUBB","HUM","HWM","IBM","ICE","IDXX","IEX","IFF","ILMN","INCY","INTC","INTU","INVH","IP","IPG","IQV","IR","IRM","ISRG","IT","ITW","IVZ","J","JBHT","JBL","JCI","JKHY","JNJ","JNPR","JPM","K","KDP","KEY","KEYS","KHC","KIM","KKR","KLAC","KMB","KMI","KMX","KO","KR","L","LDOS","LEN","LH","LHX","LIN","LKQ","LLY","LMT","LNG","LNT","LOW","LPLA","LRCX","LSXMA","LSXMK","LULU","LUV","LVS","LW","LYB","LYV","MA","MAA","MANH","MAR","MAS","MAT","MCD","MCHP","MCK","MCO","MDLZ","MDT","MET","META","MGM","MHK","MKC","MKTX","MLM","MMC","MMM","MNST","MO","MOH","MOS","MPC","MPWR","MRK","MRNA","MRO","MS","MSCI","MSFT","MSI","MTB","MTCH","MTD","MU","NDAQ","NDSN","NEE","NEM","NFLX","NI","NKE","NOC","NOW","NRG","NSC","NTAP","NTRS","NUE","NVDA","NVR","NWS","NWSA","NXPI","O","OC","ODFL","OGE","OKE","OMC","ON","ORCL","ORLY","OTIS","OXY","PANW","PARA","PAYX","PCAR","PCG","PEG","PEP","PFE","PFG","PG","PGR","PH","PHM","PINS","PKG","PLD","PLTR","PM","PNC","PNR","PODD","POOL","PPG","PPL","PRU","PSA","PSX","PTC","PWR","PYPL","QCOM","RCL","REG","REGN","RF","RGA","RHI","RJF","RL","RMD","ROK","ROL","ROP","ROST","RPM","RS","RSG","RTX","RVTY","SBAC","SBUX","SCHW","SHW","SIRI","SJM","SLB","SLG","SNA","SNAP","SNPS","SO","SOLV","SPG","SPGI","SRE","STE","STLD","STT","STX","STZ","SWK","SWKS","SYF","SYK","SYY","T","TAP","TDG","TDY","TECH","TEL","TER","TFC","TFX","TGT","TJX","TMO","TMUS","TPR","TRGP","TRMB","TROW","TRV","TSCO","TSLA","TSN","TT","TTD","TTWO","TWLO","TXN","TXT","TYL","UBER","UDR","UHS","ULTA","UNH","UNM","UNP","UPS","URI","USB","V","VICI","VLO","VMC","VRSK","VRSN","VRTX","VST","VTR","VTRS","VZ","WAB","WAL","WAT","WBA","WBD","WCC","WDC","WEC","WELL","WFC","WHR","WM","WMB","WMS","WMT","WRB","WRK","WSM","WSO","WST","WTW","WY","WYNN","XEL","XOM","XYL","YUM","Z","ZBH","ZBRA","ZION","ZTS","SPACEX","DEEPSEEK","OPENAI","BLDP","NVO","NOVO NORDISK"]);

function filterCompanies(val, content) {
  if (!val && !content) return "";
  let result = (val || "").split(", ").filter(c => !COUNTRY_NAMES.has(c)).map(c => {
    if (TICKERS.has(c)) return c;
    if (c === c.toUpperCase() && c.length <= 5) return c;
    return c.charAt(0).toUpperCase() + c.slice(1).toLowerCase();
  }).filter(Boolean).join(", ");
  if (!result && content) {
    const m = content.match(/\$([A-Z]{1,5})\b/g);
    if (m) {
      const ts = m.map(t => t.slice(1)).filter(t => TICKERS.has(t));
      if (ts.length > 0) result = ts.join(", ");
    }
    if (!result) {
      if (/NOVO\s+NORDISK/i.test(content)) result = "Novo Nordisk";
      else if (/\bDEEPSEEK\b/i.test(content)) result = "DeepSeek";
      else if (/\bSPACEX\b/i.test(content)) result = "SpaceX";
      else if (/\bOPENAI\b/i.test(content)) result = "OpenAI";
    }
  }
  return result;
}

function hasKeyword(article) {
  const text = (article.content + " " + article.companies).toLowerCase();
  return KEYWORDS.some((kw) => text.includes(kw));
}

function isTrumpStory(article) {
  return article.content.toLowerCase().includes("trump");
}

function formatTime(time) {
  if (!time) return "";
  return time.substring(0, 5);
}

function renderRows(articles) {
  const tbody = document.getElementById("news-body");
  const stats = document.getElementById("stats-count");
  stats.textContent = articles.length + " posts";
  tbody.innerHTML = articles.map((article, idx) => {
    const hl = isTrumpStory(article) ? "hl-red" : hasKeyword(article) ? "hl-yellow" : "";
    const rowClass = hl || (idx % 2 === 1 ? "alt" : "");
    const src = article.account || article.username || "";
    const url = article.url;
    const content = article.content;
    return `<tr class="${rowClass}">
      <td class="cell-date">${esc(article.date)}</td>
      <td class="cell-time">${esc(formatTime(article.time))}</td>
      <td class="cell-title">${url
        ? `<a href="${esc(url)}" target="_blank" rel="noopener" class="title-link">${esc(content)}</a>`
        : `<span class="title-text">${esc(content)}</span>`}
      </td>
      <td class="cell-company">${esc(filterCompanies(article.companies, article.content))}</td>
      <td class="cell-country">${esc(article.country || "")}</td>
      <td class="cell-source">${esc(src)}</td>
    </tr>`;
  }).join("");
}

function esc(s) {
  const div = document.createElement("div");
  div.textContent = s;
  return div.innerHTML;
}

async function fetchLive() {
  try {
    const resp = await fetch("/api/news");
    if (!resp.ok) return;
    const data = await resp.json();
    if (data.articles && data.articles.length > 0) {
      renderRows(data.articles);
    }
  } catch (_) {
    // silently fall back to build-time data
  }
}

// Fetch live data on page load, then every 60 seconds
fetchLive();
setInterval(fetchLive, 60000);
</script>

<style>
  .sheet-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 0;
  }

  .stats-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-bottom: none;
    border-radius: 8px 8px 0 0;
    font-size: 0.85rem;
    font-family: var(--font);
  }

  .stats-count {
    font-weight: 700;
    color: var(--accent);
  }

  .stats-indicator {
    font-size: 0.75rem;
    color: #22c55e;
    font-family: var(--mono);
    margin-left: auto;
  }

  .table-wrapper {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 0 0 8px 8px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
    font-family: Arial, Helvetica, sans-serif;
  }

  thead {
    position: sticky;
    top: 0;
    z-index: 1;
  }

  th {
    text-align: left;
    padding: 0.55rem 0.6rem;
    font-weight: 700;
    color: var(--text);
    font-size: 0.78rem;
    background: var(--surface);
    border-bottom: 2px solid var(--border);
    white-space: nowrap;
  }

  td {
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
    line-height: 1.4;
  }

  :global(tr.alt td) {
    background: rgba(0, 0, 0, 0.02);
  }

  :global(tr.hl-yellow td) {
    background: rgba(255, 230, 80, 0.35);
  }

  :global(tr.hl-red td) {
    background: rgba(255, 130, 130, 0.35);
  }

  :global(tr:hover td) {
    font-weight: 700;
  }

  .col-date { width: 100px; }
  .col-source { width: 120px; }
  .col-title { min-width: 350px; }

  .cell-date {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text);
    white-space: nowrap;
  }

  .cell-time {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
    white-space: nowrap;
  }

  .cell-source {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--muted);
  }

  :global(.title-link) {
    color: var(--text);
    text-decoration: none;
    transition: color 0.15s;
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.title-link:hover) {
    color: inherit;
  }

  :global(.title-text) {
    color: var(--text);
  }

  .cell-company {
    color: #4488ff;
    font-weight: 600;
    font-size: 0.8rem;
  }

  .cell-country {
    color: #4488ff;
    font-weight: 600;
    font-size: 0.78rem;
  }

  @media (max-width: 768px) {
    .sheet-container { padding: 0.5rem 0; }
    table { font-size: 0.75rem; }
    .col-date { width: 80px; }
    .col-title { min-width: 0; }
    th:nth-child(4), td:nth-child(4),
    th:nth-child(5), td:nth-child(5) { display: none; }
  }

  @media (max-width: 500px) {
    th:nth-child(6), td:nth-child(6) { display: none; }
  }
</style>
