---
import BaseLayout from "../layouts/BaseLayout.astro";

const SHEET_ID = "1-gWUmtaWJvqzEWcFFiebhoAztZ8BpU9XY4qiOfUFFLg";

interface Article {
  date: string;
  time: string;
  source: string;
  company: string;
  product: string;
  country: string;
  title: string;
  url: string;
}

function extractUrl(formula: string): string {
  const m = formula.match(/HYPERLINK\("([^"]+)"/);
  return m ? m[1] : "";
}

function cleanTitle(title: string): string {
  return title.replace(/^Opinion\w+/, "Opinion: ").replace(/^Analysis\w+/, "Analysis: ");
}

async function fetchSheet(): Promise<{ articles: Article[]; total: string; updated: string }> {
  const tokenResp = await fetch("https://oauth2.googleapis.com/token", {
    method: "POST",
    body: new URLSearchParams({
      client_id: import.meta.env.GOOGLE_CLIENT_ID,
      client_secret: import.meta.env.GOOGLE_CLIENT_SECRET,
      refresh_token: import.meta.env.GOOGLE_REFRESH_TOKEN,
      grant_type: "refresh_token",
    }),
  });
  const { access_token } = await tokenResp.json();

  const resp = await fetch(
    `https://sheets.googleapis.com/v4/spreadsheets/${SHEET_ID}/values/News%20Feed?valueRenderOption=FORMULA&majorDimension=ROWS`,
    { headers: { Authorization: `Bearer ${access_token}` } }
  );
  const data = await resp.json();
  const rows: string[][] = data.values || [];

  let total = "";
  let updated = "";
  if (rows.length > 0) {
    total = rows[0][0] || "";
    updated = (rows[0][6] || "").replace("Updated: ", "");
  }

  const articles: Article[] = [];
  for (let i = 2; i < rows.length; i++) {
    const r = rows[i];
    if (r.length < 8) continue;
    articles.push({
      date: r[0] || "",
      time: r[1] || "",
      source: r[2] || "",
      company: r[3] || "",
      product: r[4] || "",
      country: r[5] || "",
      title: cleanTitle(r[6] || ""),
      url: extractUrl(r[7] || ""),
    });
  }

  return { articles, total, updated };
}

const { articles, total, updated } = await fetchSheet();

const sourceLabels: Record<string, string> = {
  Bloomberg: "Bloomberg",
  FT: "FT",
  Twitter: "Twitter",
};
---

<BaseLayout title="News Feed" description="Curated energy & market news from Bloomberg, FT, and Twitter.">
  <div class="sheet-container">
    <div class="stats-row">
      <span class="stats-count">{total}</span>
      <span class="stats-updated">Last updated: {updated}</span>
    </div>

    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th class="col-date">Date</th>
            <th>Time</th>
            <th class="col-source">Source</th>
            <th class="col-title">Title</th>
            <th>Company</th>
            <th>Product</th>
            <th>Country</th>
          </tr>
        </thead>
        <tbody>
          {articles.map((article, idx) => (
            <tr class={idx % 2 === 1 ? "alt" : ""}>
              <td class="cell-date">{article.date}</td>
              <td class="cell-time">{article.time}</td>
              <td class="cell-source">{sourceLabels[article.source] || article.source}</td>
              <td class="cell-title">
                <a href={article.url} target="_blank" rel="noopener" class="title-link">{article.title}</a>
              </td>
              <td class="cell-company">{article.company || ""}</td>
              <td class="cell-product">{article.product || ""}</td>
              <td class="cell-country">{article.country || ""}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>

<style>
  .sheet-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 0;
  }

  .stats-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-bottom: none;
    border-radius: 8px 8px 0 0;
    font-size: 0.85rem;
    font-family: var(--font);
  }

  .stats-count {
    font-weight: 700;
    color: var(--accent);
  }

  .stats-updated {
    color: var(--muted);
    font-family: var(--mono);
    font-size: 0.8rem;
  }

  .table-wrapper {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 0 0 8px 8px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
    font-family: Arial, Helvetica, sans-serif;
  }

  thead {
    position: sticky;
    top: 0;
    z-index: 1;
  }

  th {
    text-align: left;
    padding: 0.55rem 0.6rem;
    font-weight: 700;
    color: var(--text);
    font-size: 0.78rem;
    background: var(--surface);
    border-bottom: 2px solid var(--border);
    white-space: nowrap;
  }

  td {
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
    line-height: 1.4;
  }

  tr.alt td {
    background: rgba(255, 255, 255, 0.015);
  }

  tr:hover td {
    background: rgba(0, 212, 255, 0.04);
  }

  .col-date { width: 100px; }
  .col-source { width: 80px; }
  .col-title { min-width: 300px; }

  .cell-date {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text);
    white-space: nowrap;
  }

  .cell-time {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
    white-space: nowrap;
  }

  .cell-source {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
  }

  .title-link {
    color: var(--text);
    text-decoration: none;
    transition: color 0.15s;
  }

  .title-link:hover {
    color: #4488ff;
  }

  .cell-company {
    color: #4488ff;
    font-weight: 600;
    font-size: 0.8rem;
  }

  .cell-product {
    color: var(--muted);
    font-size: 0.78rem;
  }

  .cell-country {
    color: #4488ff;
    font-weight: 600;
    font-size: 0.78rem;
  }

  @media (max-width: 768px) {
    .sheet-container { padding: 0.5rem 0; }
    table { font-size: 0.75rem; }
    .col-date { width: 80px; }
    .col-title { min-width: 0; }
    th:nth-child(5), td:nth-child(5),
    th:nth-child(6), td:nth-child(6) { display: none; }
  }

  @media (max-width: 500px) {
    th:nth-child(7), td:nth-child(7) { display: none; }
  }
</style>
