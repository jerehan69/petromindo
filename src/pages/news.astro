---
import BaseLayout from "../layouts/BaseLayout.astro";

const SHEET_ID = import.meta.env.SHEET_ID;

interface Article {
  date: string;
  time: string;
  source: string;
  company: string;
  product: string;
  country: string;
  title: string;
  url: string;
}

function extractUrl(formula: string): string {
  const m = formula.match(/HYPERLINK\("([^"]+)"/);
  return m ? m[1] : "";
}

function cleanTitle(title: string): string {
  return title.replace(/^Opinion\w+/, "Opinion: ").replace(/^Analysis\w+/, "Analysis: ");
}

const KEYWORDS = ["lng", "gas", "oil", "coal", "nuclear", "lithium", "gold", "iron ore", "copper"];

function hasKeyword(article: Article): boolean {
  const text = `${article.title} ${article.product}`.toLowerCase();
  return KEYWORDS.some((kw) => text.includes(kw));
}

function isTopStory(article: Article): boolean {
  return article.company.includes("Trump");
}

function toSGT(time: string, source: string): string {
  if (!time || !source) return String(time ?? "");
  let h: number, m: string;
  if (typeof time === "number" || /^\d+\.?\d*$/.test(String(time).trim())) {
    const serial = typeof time === "number" ? time : parseFloat(time);
    const totalMinutes = Math.round(serial * 24 * 60);
    h = Math.floor(totalMinutes / 60);
    m = String(totalMinutes % 60).padStart(2, "0");
  } else {
    const parts = String(time).split(":");
    if (parts.length < 2) return String(time);
    h = parseInt(parts[0], 10);
    m = parts[1];
    if (isNaN(h)) return String(time);
  }
  return `${String(h).padStart(2, "0")}:${m}`;
}

function formatDate(date: string): string {
  if (!date) return "";
  if (typeof date === "number" || /^\d+\.?\d*$/.test(String(date).trim())) {
    const serial = typeof date === "number" ? date : parseFloat(date);
    const d = new Date(1899, 11, 30 + serial);
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
  }
  return String(date);
}

async function fetchSheet(): Promise<{ articles: Article[]; total: string; updated: string }> {
  const tokenResp = await fetch("https://oauth2.googleapis.com/token", {
    method: "POST",
    body: new URLSearchParams({
      client_id: import.meta.env.GOOGLE_CLIENT_ID,
      client_secret: import.meta.env.GOOGLE_CLIENT_SECRET,
      refresh_token: import.meta.env.GOOGLE_REFRESH_TOKEN,
      grant_type: "refresh_token",
    }),
  });
  const { access_token } = await tokenResp.json();

  const resp = await fetch(
    `https://sheets.googleapis.com/v4/spreadsheets/${SHEET_ID}/values/News%20Feed?valueRenderOption=FORMULA&majorDimension=ROWS`,
    { headers: { Authorization: `Bearer ${access_token}` } }
  );
  const data = await resp.json();
  const rows: string[][] = data.values || [];

  let total = "";
  let updated = "";
  if (rows.length > 0) {
    total = rows[0][0] || "";
    updated = (rows[0][6] || "").replace("Updated: ", "");
  }

  const articles: Article[] = [];
  for (let i = 2; i < rows.length; i++) {
    const r = rows[i];
    if (r.length < 8) continue;
    articles.push({
      date: r[0] || "",
      time: r[1] || "",
      company: r[2] || "",
      product: r[3] || "",
      country: r[4] || "",
      title: cleanTitle(r[5] || ""),
      source: r[6] || "",
      url: extractUrl(r[7] || ""),
    });
  }

  return { articles, total, updated };
}

function sortKey(article: Article): string {
  const sgtTime = toSGT(article.time, article.source);
  return `${formatDate(article.date)}T${sgtTime}`;
}

const { articles, total, updated } = await fetchSheet();
articles.sort((a, b) => sortKey(b).localeCompare(sortKey(a)));

const sourceLabels: Record<string, string> = {
  Bloomberg: "Bloomberg",
  FT: "FT",
  Twitter: "Twitter",
};
---

<BaseLayout title="News Feed" description="Curated energy & market news from Bloomberg, FT, and Twitter.">
  <div class="sheet-container">
    <div class="stats-row">
      <span class="stats-count">{total}</span>
      <span class="stats-updated">Last updated: {updated}</span>
    </div>

    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th class="col-date">Date</th>
            <th>Time</th>
            <th>Company</th>
            <th>Product</th>
            <th>Country</th>
            <th class="col-title">Title</th>
            <th class="col-source">Source</th>
          </tr>
        </thead>
        <tbody>
          {articles.map((article, idx) => {
            const hl = hasKeyword(article) ? "hl-yellow" : isTopStory(article) ? "hl-pink" : "";
            const rowClass = hl || (idx % 2 === 1 ? "alt" : "");
            return (
            <tr class={rowClass}>
              <td class="cell-date">{formatDate(article.date)}</td>
              <td class="cell-time">{toSGT(article.time, article.source)}</td>
              <td class="cell-company">{article.company || ""}</td>
              <td class="cell-product">{article.product || ""}</td>
              <td class="cell-country">{article.country || ""}</td>
              <td class="cell-title">
                <a href={article.url} target="_blank" rel="noopener" class="title-link">{article.title}</a>
              </td>
              <td class="cell-source">{sourceLabels[article.source] || article.source}</td>
            </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>

<style>
  .sheet-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 0;
  }

  .stats-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-bottom: none;
    border-radius: 8px 8px 0 0;
    font-size: 0.85rem;
    font-family: var(--font);
  }

  .stats-count {
    font-weight: 700;
    color: var(--accent);
  }

  .stats-updated {
    color: var(--muted);
    font-family: var(--mono);
    font-size: 0.8rem;
  }

  .table-wrapper {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 0 0 8px 8px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
    font-family: Arial, Helvetica, sans-serif;
  }

  thead {
    position: sticky;
    top: 0;
    z-index: 1;
  }

  th {
    text-align: left;
    padding: 0.55rem 0.6rem;
    font-weight: 700;
    color: var(--text);
    font-size: 0.78rem;
    background: var(--surface);
    border-bottom: 2px solid var(--border);
    white-space: nowrap;
  }

  td {
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
    line-height: 1.4;
  }

  tr.alt td {
    background: rgba(255, 255, 255, 0.015);
  }

  tr.hl-yellow td {
    background: rgba(255, 255, 200, 0.15);
  }

  tr.hl-pink td {
    background: rgba(255, 200, 200, 0.12);
  }

  tr:hover td {
    background: rgba(0, 212, 255, 0.04) !important;
  }

  .col-date { width: 100px; }
  .col-source { width: 80px; }
  .col-title { min-width: 300px; }

  .cell-date {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text);
    white-space: nowrap;
  }

  .cell-time {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
    white-space: nowrap;
  }

  .cell-source {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
  }

  .title-link {
    color: var(--text);
    text-decoration: none;
    transition: color 0.15s;
  }

  .title-link:hover {
    color: #4488ff;
  }

  .cell-company {
    color: #4488ff;
    font-weight: 600;
    font-size: 0.8rem;
  }

  .cell-product {
    color: #cc3333;
    font-weight: 600;
    font-size: 0.78rem;
  }

  .cell-country {
    color: #4488ff;
    font-weight: 600;
    font-size: 0.78rem;
  }

  @media (max-width: 768px) {
    .sheet-container { padding: 0.5rem 0; }
    table { font-size: 0.75rem; }
    .col-date { width: 80px; }
    .col-title { min-width: 0; }
    th:nth-child(5), td:nth-child(5),
    th:nth-child(6), td:nth-child(6) { display: none; }
  }

  @media (max-width: 500px) {
    th:nth-child(7), td:nth-child(7) { display: none; }
  }
</style>
